# ──────────────────────────────────────────────────────
# LLM 配置 · 三件套 + 可选项
# 道法：base_url + api_key + model，凡 OpenAI 兼容皆可
# 用法：复制此文件为 .env（同目录），填入真实 key
# .env 不入 git
# ──────────────────────────────────────────────────────

# ── 默认 profile（凡未指定时用此）──────────────────────
# OpenAI 原家
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# DeepSeek（含视觉之 deepseek-vl，文本 deepseek-chat / deepseek-reasoner）
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_MODEL=deepseek-chat

# 通义千问（OpenAI 兼容入口）
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# OPENAI_MODEL=qwen-plus

# Moonshot Kimi
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.moonshot.cn/v1
# OPENAI_MODEL=moonshot-v1-8k

# 智谱 GLM
# OPENAI_API_KEY=...
# OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# OPENAI_MODEL=glm-4-flash

# 本地 Ollama
# OPENAI_API_KEY=ollama   # 占位即可
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_MODEL=qwen2.5:14b

# 本地 LM Studio / vLLM
# OPENAI_API_KEY=lm-studio
# OPENAI_BASE_URL=http://localhost:1234/v1
# OPENAI_MODEL=qwen2.5-vl-7b-instruct


# ── 视觉 profile（专用·当 default 之模型无视觉时启）──
# LLM_VISION_API_KEY=sk-...
# LLM_VISION_BASE_URL=https://api.openai.com/v1
# LLM_VISION_MODEL=gpt-4o

# 通义视觉
# LLM_VISION_API_KEY=sk-...
# LLM_VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_VISION_MODEL=qwen-vl-max

# DeepSeek-VL
# LLM_VISION_API_KEY=sk-...
# LLM_VISION_BASE_URL=https://api.deepseek.com/v1
# LLM_VISION_MODEL=deepseek-vl


# ── 长文 profile（写期末汇编/章节素材时启）─────────────
# LLM_LONG_API_KEY=sk-...
# LLM_LONG_BASE_URL=https://api.moonshot.cn/v1
# LLM_LONG_MODEL=moonshot-v1-128k


# ── 共用调参（所有 profile 共用）─────────────────────
# LLM_TEMPERATURE=0.3
# LLM_MAX_TOKENS=4096
# LLM_TIMEOUT=120
# LLM_RETRIES=3
# LLM_CACHE=1   # 0 关闭缓存
