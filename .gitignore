# ── 道法自然 · 学习复习 .gitignore ──
# 善行者无辙迹 · 敏感不入仓

# ── 凭证 / 会话 ──
.env
.yuketang/
.session_cache.txt

# ── LLM 缓存 ──
.llm_cache/

# ── 浏览器 profile（含 cookie） ──
**/pw_profile/
**/edge_pw_profile/

# ── Python 缓存 ──
__pycache__/
*.pyc
*.pyo

# ── 系统文件 ──
Thumbs.db
Desktop.ini
.DS_Store

# ── PDF（总量5.4GB超GitHub限额，排除之；解析成果MD已含文本） ──
*.pdf

# ── 图片（解析生成page_XXX.jpg共12361个，文本已入MD） ──
*.jpg
*.jpeg
*.png
*.gif
*.bmp
*.webp
*.svg
*.ico

# ── 日志（一律不入仓 · 戒律五） ──
*.log

# ── 中间产物 / 冗余源（不入版本控制 · 戒律五，本地保留可用） ──
解析仓库/
.道喂任务/
.模拟卷任务/
.图道_测试/
雨课堂PDF/

# 课件页图（公网站点资源，纳入版本控制）
!docs/assets/pdf/
!docs/assets/pdf/**

# 本地辅助脚本/隧道凭据，勿入库
_bridge.py
_payload_*.py
_bgjobs/
